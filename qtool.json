{
    "dependences": [
        {
            "key": "qbase",
            "local_path": "~/Project/Github/script-qbase/qbase"
        }
    ],
    "quickCmd": [
        {
            "type": "branchCheck",
            "des": "分支的检查(打包使用的分支名、必须包含的分支、相对上次缺失的分支）",
            "values": [
                {
                    "des": "检查指定的分支能否打包指定的环境",
                    "key": "branchCheck_selfName",
                    "rel_path": "./branch/branch_check_self_name.sh",
                    "example": "qtool -quick branchCheck_selfName"
                },
                {
                    "des": "检查指定的分支有没有合入其必须合入的所有分支",
                    "key": "branchCheck_missing_by_must",
                    "rel_path": "./branch/branch_check_missing_by_must.sh",
                    "example": "qtool -quick branchCheck_missing_by_must"
                },
                {
                    "des": "检查本分支的本次打包是否漏掉本分支上次打包的分支",
                    "key": "branchCheck_missing_diff_old",
                    "rel_path": "./branch/branch_check_missing_diff_old.sh",
                    "example": "qtool -quick branchCheck_missing_diff_old"
                },
                {
                    "des": "检查本分支：1能否打包指定的环境、2本次打包有没有合入其必须合入的所有分支、3本次打包是否漏掉本分支上次打包的分支",
                    "key": "branchCheck_all",
                    "rel_path": "./branch/branch_check_all.sh",
                    "example": "qtool -quick branch_check_all"
                },
                {
                    "des": "获取当前分支【在rebase指定分支后】的所有分支信息合入指定文件中，并进行整理及整理后发送通知",
                    "key": "getBranchMapsAccordingToRebaseBranch",
                    "rel_path": "./branch_quickcmd/getBranchMapsAccordingToRebaseBranch.sh",
                    "example": "qtool -quick getBranchMapsAccordingToRebaseBranch -rebaseBranch \"${REBASE_BRANCH}\" --add-value \"${add_value}\" -onlyName \"${ONLY_NAME}\" -checkInNetwork \"${CHECK_IN_NETWORK_TYPE}\" -checkByJsonFile \"${CHECK_BY_JSON_FILE}\" -mustContainByJsonFile \"${MUST_CONTAIN_BY_JSON_FILE}\" -shouldCheckMissingDiffOld \"${shouldCheckMissingDiffOld}\" -lastPackBranchNames \"${LAST_PACK_BRANCH_NAMES}\" -lastPackFromDate \"${LAST_PACK_FROM_DATE}\" -lastOnlineBranchNames \"${LAST_ONLINE_BRANCH_NAMES}\" -peoJsonF \"${Personnel_FILE_PATH}\" -branchMapsFromDir \"${BranceMaps_From_Directory_PATH}\" -branchMapsAddToJsonF \"${BranchMapAddToJsonFile}\" -branchMapsAddToKey \"${BranchMapAddToKey}\" -ignoreCheckBranchNames \"${ignoreCheckBranchNameArray}\" -shouldDeleteHasCatchRequestBranchFile \"${shouldDeleteHasCatchRequestBranchFile}\" -robot \"${ROBOT_URL}\" -at \"${atMiddleBracketIdsString[*]}\""
                }
            ]
        },
        {
            "type": "branchJsonFile",
            "des": "分支信息json文件的处理(创建、更新）",
            "values": [
                {
                    "des": "branchJsonFile 分支信息文件的创建",
                    "key": "branchJsonFile_create",
                    "rel_path": "./src/branchJsonFile_create.py",
                    "example": "qtool -quick branchJsonFile_create -tool_params_file_path \"${tool_params_file_path}\""
                },
                {
                    "des": "branchJsonFile 分支信息文件的更新",
                    "key": "branchJsonFile_update",
                    "rel_path": "./src/branchJsonFile_update.py",
                    "example": "qtool -quick branchJsonFile_update -tool_params_file_path \"${tool_params_file_path}\""
                }
            ]
        }
    ],
    "support_script_path": [
        {
            "type": "config",
            "des": "配置文件路径",
            "values": [
                {
                    "key": "config_env_keys_menu",
                    "des": "qtool 环境变量集合/菜单的配置文件路径（只读 ~/.qtool/config/ 本地副本，不存在则提示先执行 qtool init）",
                    "rel_path": "./init/qtool_env_keys_menu.json",
                    "example": "qtool -path config_env_keys_menu"
                }
            ]
        },
        {
            "type": "website",
            "des": "网站",
            "values": [
                {
                    "des": "罗列之类类型的网站列表，并在进行选中后打开所选中的网站",
                    "key": "openWebsiteByCustomChoose",
                    "rel_path": "./src/openWebsiteByCustomChoose.py",
                    "example": "qtool -path openWebsiteByCustomChoose"
                }
            ]
        },
        {
            "type": "source",
            "des": "source",
            "values": [
                {
                    "des": "qtool 菜单的函数库",
                    "key": "qtool_menu_source",
                    "rel_path": "./qtool_menu_source.sh",
                    "example": "qtool -path qtool_menu_source"
                }
            ]
        },
        {
            "type": "upload",
            "des": "上传",
            "values": [
                {
                    "des": "上传参数的获取 -- pgyer",
                    "key": "getUploadArg_pgyer",
                    "rel_path": "./upload_arg_get/getUploadArg_pgyer.sh",
                    "example": "responseJsonString=$(sh xxx/xx.sh -pgyerJsonsFPath \"${Pgyer_Download_FILE_PATH}\" -pgyerJsonsFKey \"${Pgyer_Download_FILE_KEY}\" -pgyerUploadUrlType \"${PgyerUploadUrlType}\" -pl \"${PlatformType}\" -pn \"${PackageNetworkType}\" -curBranchName \"${CurrentBranchName}\")"
                },
                {
                    "des": "上传安装包到 各个平台(pgyer、cos、testFlight),平台参数来源于文件。并在上传结束,获取安装包的各种路径信息",
                    "key": "upload_to_all_and_log",
                    "rel_path": "./upload/upload_to_all_and_log.sh",
                    "example": "responseJsonString=$(sh xxx/upload_to_all_and_log.sh -ipa \"${ipa_file_path}\" -updateDesString \"${updateDesString}\" -updateDesFromFilePath \"${updateDesFromFilePath}\" -updateDesFromFileKey \"${updateDesFromFileKey}\" -uploadArgsFPath \"${UploadPlatformArgsFilePath}\" -uploadArgsFKey \"${UploadPlatformArgsFileKey}\" -uploadResultFPath \"${UploadResult_FILE_PATH}\" -uploadResultFKey \"${UploadResult_FILE_Key}\" -LogPostToRobotUrl \"${LogPostToRobotUrl}\" -LogPostTextHeader \"${LogPostTextHeader}\")"
                }
            ]
        }
    ]
}